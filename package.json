{
  "name": "@arising/characters",
  "version": "1.0.0",
  "description": "Contracts for Arising characters ERC721 tokens",
  "bugs": {
    "url": "https://github.com/playarising/characters/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/playarising/characters/.git"
  },
  "license": "MIT",
  "author": "Enrique Berrueta",
  "scripts": {
    "ci": "env CI=true",
    "compile": "hardhat compile",
    "coverage": "env COVERAGE=true hardhat coverage",
    "format": "prettier --write '**/*.{sol,js,json,md}' && yarn run sort",
    "gas-report": "env ENABLE_GAS_REPORT=true yarn test",
    "sort": "npx sort-package-json",
    "test": "hardhat test"
  },
  "devDependencies": {
    "@nomiclabs/hardhat-ethers": "2.1.0",
    "@nomiclabs/hardhat-waffle": "2.0.3",
    "@openzeppelin/contracts": "4.7.1",
    "chai": "4.3.6",
    "ethereum-waffle": "3.4.4",
    "ethers": "5.6.9",
    "hardhat": "2.10.1",
    "hardhat-gas-reporter": "1.0.8",
    "prettier": "2.7.1",
    "prettier-plugin-solidity": "1.0.0-dev.23",
    "solidity-coverage": "0.7.21"
  },
  "engines": {
    "node": "14.x"
  }
}
